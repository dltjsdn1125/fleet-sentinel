# ── Supabase Postgres (FleetSentinel 테이블은 스키마 `fleetsentinel`)
# 대시보드 → Project Settings → Database → Connection string (URI)
# 마이그레이션은 MCP로 적용됨. 로컬/배포 모두 아래에 DB 비밀번호 넣기.
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"

# 마이그레이션 전용으로 직접 연결이 필요하면 (선택): 5432 세션 모드 URI를 추가로 쓰고 prisma migrate 시에만 지정

# ── NextAuth
NEXTAUTH_URL="http://localhost:3000"
AUTH_SECRET="랜덤-긴-문자열"
# 또는 NEXTAUTH_SECRET

# ── OAuth (선택)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── Supabase 클라이언트 (브라우저에서 Storage/Realtime 쓸 때만)
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[anon-key-from-dashboard]"

# ── Stripe (선택)
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
