# ═══════════════════════════════════════════════════════════════════════════
# FleetSentinel — Supabase Postgres 만 사용 (Docker 불필요)
# ═══════════════════════════════════════════════════════════════════════════
#
# 1) Supabase 대시보드 → Project Settings → Database
# 2) Connection string → URI 복사 (비밀번호는 [YOUR-PASSWORD] 자리에 DB 비밀번호)
#
# prisma db push(스키마 반영)는 Transaction pooler(6543)에서 실패하는 경우가 있습니다.
# 그럴 때는 같은 화면의 "Direct connection" 또는 Session mode URI 를 아래에 사용하세요.
#
# 중요: Prisma 는 FLEET_DATABASE_URL 만 읽습니다 (시스템 DATABASE_URL 과 무관).

# 예: Direct / Session (db push·앱 둘 다에 무난)
# FLEET_DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres"

# 예: Transaction pooler (앱 런타임용, push 실패 시 위 Direct 로 바꿔서 push 후 다시 pooler 로)
# FLEET_DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"

FLEET_DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres"

# ── NextAuth (dev 서버는 package.json 기준 포트 3010)
NEXTAUTH_URL="http://localhost:3010"
AUTH_URL="http://localhost:3010"
AUTH_SECRET="랜덤-긴-문자열-배포시-필수"
# 또는 NEXTAUTH_SECRET

# ── OAuth (선택)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── Supabase 클라이언트 (Storage/Realtime 등 브라우저 연동 시)
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[anon-key-from-dashboard]"

# ── Stripe (선택)
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
