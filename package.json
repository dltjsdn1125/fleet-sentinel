{
  "name": "fleet-sentinel",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev -p 3010",
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\"",
    "build": "prisma generate && next build",
    "start": "next start -p 3010",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:seed": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:set-url": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/set-fleet-database-url.ps1",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "bootstrap": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/bootstrap.ps1",
    "bootstrap:supabase": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/bootstrap.ps1 -Supabase",
    "supabase:login": "supabase login",
    "supabase:link": "supabase link --project-ref jnpxwcmshukhkxdzicwv"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@auth/prisma-adapter": "^2.7.4",
    "@prisma/client": "^6.3.1",
    "@stripe/stripe-js": "^9.0.0",
    "@types/leaflet": "^1.9.21",
    "bcryptjs": "^2.4.3",
    "exceljs": "^4.4.0",
    "leaflet": "^1.9.4",
    "next": "^15.1.7",
    "next-auth": "^5.0.0-beta.25",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-leaflet": "^5.0.0",
    "stripe": "^21.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.20",
    "eslint": "^9",
    "eslint-config-next": "^15.1.7",
    "postcss": "^8.5.1",
    "prisma": "^6.3.1",
    "supabase": "^2.84.4",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
